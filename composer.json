{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "numerar/contable",
    "type": "library",
    "description": "Numerar Contable — Motor contable de partida doble con PUC colombiano para Laravel.",
    "keywords": ["laravel", "accounting", "contabilidad", "puc", "colombia", "double-entry"],
    "license": "MIT",
    "authors": [
        {
            "name": "Numerar",
            "email": "asesorboss1.0@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Numerar\\Contable\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Numerar\\Contable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Numerar\\Contable\\ContableServiceProvider"
            ],
            "aliases": {
                "Contable": "Numerar\\Contable\\Facades\\Contable"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
